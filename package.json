{
  "name": "@richhaase/c2",
  "version": "0.3.3",
  "description": "CLI tool for syncing and analyzing Concept2 rowing data",
  "keywords": [
    "concept2",
    "rowing",
    "erg",
    "fitness",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/richhaase/c2.git"
  },
  "author": "Rich Haase",
  "type": "module",
  "bin": {
    "c2": "src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "test": "bun test",
    "check": "tsc --noEmit && biome check src/ && bun test",
    "lint": "biome check src/",
    "fmt": "biome check --write src/",
    "release": "bun run check && npm version"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.9"
  },
  "files": [
    "src"
  ],
  "engines": {
    "bun": ">=1.0.0"
  }
}
